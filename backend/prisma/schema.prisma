generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum DecisionType {
  ALLOW
  DENY
  STEP_UP
}

model User {
  id               String       @id @default(uuid()) @db.Uuid
  username         String       @unique @db.VarChar(50)
  email            String       @unique @db.VarChar(100)
  firstName        String?      @map("first_name") @db.VarChar(100)
  lastName         String?      @map("last_name") @db.VarChar(100)
  department       String?      @db.VarChar(120)
  passwordHash     String       @map("password_hash")
  roleId           String       @map("role_id") @db.Uuid
  mfaSecret        String?      @map("mfa_secret") @db.VarChar(255)
  mfaEnabled       Boolean      @default(false) @map("mfa_enabled")
  createdAt        DateTime     @default(now()) @map("created_at")
  status           UserStatus   @default(ACTIVE)

  role             Role         @relation(fields: [roleId], references: [id])
  patientProfile   Patient?     @relation("PatientUser")
  devices          Device[]
  refreshTokens    RefreshToken[]
  ehrAsDoctor      EHR[]        @relation("DoctorEHR")
  assignedPatients Patient[]    @relation("AssignedDoctor")
  auditLogs        AuditLog[]

  @@map("users")
}

/// Read-only view of users joined with roles.role_name (for browsing; use User for writes).
model UserWithRoleName {
  id           String     @id @db.Uuid
  username     String     @db.VarChar(50)
  email        String     @db.VarChar(100)
  firstName    String?    @map("first_name") @db.VarChar(100)
  lastName     String?    @map("last_name") @db.VarChar(100)
  department   String?    @db.VarChar(120)
  passwordHash String     @map("password_hash")
  roleId       String     @map("role_id") @db.Uuid
  roleName     String     @map("role_name") @db.VarChar(50)
  mfaSecret    String?    @map("mfa_secret") @db.VarChar(255)
  mfaEnabled   Boolean    @map("mfa_enabled")
  createdAt    DateTime   @map("created_at")
  status       UserStatus

  @@map("users_with_role_names")
}

model Role {
  id               String             @id @default(uuid()) @db.Uuid
  roleName         String             @unique @map("role_name") @db.VarChar(50)
  description      String?

  users            User[]
  rolePermissions  RolePermission[]

  @@map("roles")
}

model Permission {
  id               String             @id @default(uuid()) @db.Uuid
  permissionName   String             @map("permission_name") @db.VarChar(100)
  resource         String             @db.VarChar(100)
  action           String             @db.VarChar(50)

  rolePermissions  RolePermission[]

  @@unique([permissionName, resource, action])
  @@map("permissions")
}

model RolePermission {
  id               String       @id @default(uuid()) @db.Uuid
  roleId           String       @map("role_id") @db.Uuid
  permissionId     String       @map("permission_id") @db.Uuid

  role             Role         @relation(fields: [roleId], references: [id])
  permission       Permission   @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Patient {
  id                   String      @id @default(uuid()) @db.Uuid
  userId               String      @unique @map("user_id") @db.Uuid
  medicalRecordNumber  String      @unique @map("medical_record_number") @db.VarChar(50)
  assignedDoctorId     String?     @map("assigned_doctor_id") @db.Uuid
  createdAt            DateTime    @default(now()) @map("created_at")

  user                 User        @relation("PatientUser", fields: [userId], references: [id])
  assignedDoctor       User?       @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id])
  ehrRecords           EHR[]

  @@map("patients")
}

/// Read-only view: patients plus patient account username/email (use Patient for writes).
model PatientWithUserDetails {
  id                  String   @id @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  username            String   @db.VarChar(50)
  email               String   @db.VarChar(100)
  medicalRecordNumber String   @map("medical_record_number") @db.VarChar(50)
  assignedDoctorId    String?  @map("assigned_doctor_id") @db.Uuid
  createdAt           DateTime @map("created_at")

  @@map("patients_with_user_details")
}

model Device {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  userAgent String   @map("user_agent") @db.VarChar(1024)
  ip        String?  @map("ip") @db.VarChar(100)
  timezone  String?  @map("timezone") @db.VarChar(100)
  lastSeen  DateTime @default(now()) @map("last_seen")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, userAgent])
  @@map("devices")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.VarChar(512)
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

/// Read-only view: refresh tokens plus user username/email (use RefreshToken for writes).
model RefreshTokenWithUserDetails {
  id        String   @id @db.Uuid
  token     String   @db.VarChar(512)
  userId    String   @map("user_id") @db.Uuid
  username  String   @db.VarChar(50)
  email     String   @db.VarChar(100)
  expiresAt DateTime @map("expires_at")

  @@map("refresh_tokens_with_user_details")
}

model EHR {
  id            String      @id @default(uuid()) @db.Uuid
  patientId     String      @map("patient_id") @db.Uuid
  doctorId      String      @map("doctor_id") @db.Uuid
  diagnosis     String
  vitals        Json?
  s3FileKey     String?     @map("s3_file_key") @db.VarChar(255)
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at")

  patient       Patient     @relation(fields: [patientId], references: [id])
  doctor        User        @relation("DoctorEHR", fields: [doctorId], references: [id])

  @@map("ehr")
}

/// Read-only view: EHR plus patient & doctor username/email (use EHR for writes).
model EHRWithUserEmails {
  id              String   @id @db.Uuid
  patientId       String   @map("patient_id") @db.Uuid
  doctorId        String   @map("doctor_id") @db.Uuid
  patientUsername String   @map("patient_username") @db.VarChar(50)
  patientEmail    String   @map("patient_email") @db.VarChar(100)
  doctorUsername  String   @map("doctor_username") @db.VarChar(50)
  doctorEmail     String   @map("doctor_email") @db.VarChar(100)
  diagnosis       String
  vitals          Json?
  s3FileKey       String?  @map("s3_file_key") @db.VarChar(255)
  updatedAt       DateTime @map("updated_at")

  @@map("ehr_with_user_emails")
}

model AuditLog {
  id           String        @id @default(uuid()) @db.Uuid
  timestamp    DateTime      @default(now())
  userId       String?       @map("user_id") @db.Uuid
  action       String        @db.VarChar(100)
  resourceId   String?       @map("resource_id") @db.VarChar(100)
  decision     DecisionType
  trustScore   Int?          @map("trust_score")
  ipAddress    String?       @map("ip_address") @db.VarChar(100)

  user         User?         @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

/// Read-only view: audit logs plus username/email when user_id is present (use AuditLog for writes).
model AuditLogWithUserDetails {
  id         String       @id @db.Uuid
  timestamp  DateTime
  userId     String?      @map("user_id") @db.Uuid
  username   String?      @db.VarChar(50)
  email      String?      @db.VarChar(100)
  action     String       @db.VarChar(100)
  resourceId String?      @map("resource_id") @db.VarChar(100)
  decision   DecisionType
  trustScore Int?         @map("trust_score")
  ipAddress  String?      @map("ip_address") @db.VarChar(100)

  @@map("audit_logs_with_user_details")
}