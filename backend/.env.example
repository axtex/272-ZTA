# Copy to `.env` in this folder. Never commit real credentials.

# Local Postgres (matches root `docker compose up -d`; default host port 5432).
# If 5432 is already taken: `POSTGRES_HOST_PORT=5433 docker compose up -d` and use :5433 below.
DATABASE_URL="postgresql://hospital:hospital@localhost:5432/hospital_db?schema=public"

# Hosted Postgres (Neon, Supabase, Railway, etc.): replace with your provider URL.
# Share one dev database URL with the team via a password manager or chat, not in git.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require&schema=public"