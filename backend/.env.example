#supabase connection string
# Supabase via connection pooling (transaction pooler) for runtime queries.
DATABASE_URL="postgresql://postgres.rrvatrfwkictlvmghfsx:YOUR-PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&uselibpqcompat=true&sslmode=require"

# Direct/session connection for migrations.
DIRECT_URL="postgresql://postgres.rrvatrfwkictlvmghfsx:YOUR-PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres?uselibpqcompat=true&sslmode=require"

# TLS certificate validation for the runtime DB connection (node-postgres).
# For demos/dev, leaving this unset defaults to `false` (accept self-signed/unknown CAs).
# Set to true if you have proper CA trust configured (recommended long-term).
# PG_SSL_REJECT_UNAUTHORIZED=true

# Required for POST /api/auth/login (use a long random string in real deployments).
JWT_SECRET="change-me-to-a-long-random-string"
# JWT_EXPIRES_IN=15m

# Required to issue refresh tokens.
REFRESH_TOKEN_SECRET="change-me-to-a-long-random-string"
